# ─── Database ────────────────────────────────────────────────────────────────
# MySQL connection string (Railway MySQL, PlanetScale, or any MySQL 8+ host)
DATABASE_URL=mysql://user:password@host:3306/noor_marketplace

# ─── Auth ────────────────────────────────────────────────────────────────────
# Random secret used to sign JWT session cookies — change this in production!
JWT_SECRET=change-me-to-a-long-random-string-in-production

# ─── Server ──────────────────────────────────────────────────────────────────
NODE_ENV=production
PORT=3000

# ─── Stripe Payments (optional — payments disabled if not set) ───────────────
STRIPE_SECRET_KEY=sk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...

# ─── AI Product Import — powered by Groq (free, fast) ──────────────────────
# Get your free API key at https://console.groq.com
GROQ_API_KEY=gsk_...
# LLM_MODEL=llama-3.3-70b-versatile  # default (change if needed)
# LLM_API_URL=https://api.groq.com/openai/v1/chat/completions  # default

# ─── AWS S3 Image Storage (optional — images stored as URLs if not set) ──────
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1
S3_BUCKET=
