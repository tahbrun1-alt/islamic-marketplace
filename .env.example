# ─── Database ────────────────────────────────────────────────────────────────
# MySQL connection string (Railway MySQL, PlanetScale, or any MySQL 8+ host)
DATABASE_URL=mysql://user:password@host:3306/noor_marketplace

# ─── Auth ────────────────────────────────────────────────────────────────────
# Random secret used to sign JWT session cookies — change this in production!
JWT_SECRET=change-me-to-a-long-random-string-in-production

# ─── Server ──────────────────────────────────────────────────────────────────
NODE_ENV=production
PORT=3000

# ─── Stripe Payments (optional — payments disabled if not set) ───────────────
STRIPE_SECRET_KEY=sk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...

# ─── AI Product Import (optional — import feature disabled if not set) ───────
# Any OpenAI-compatible endpoint works (OpenAI, Together AI, Groq, etc.)
OPENAI_API_KEY=sk-...
LLM_MODEL=gpt-4o-mini
# LLM_API_URL=https://api.openai.com/v1/chat/completions  # default

# ─── AWS S3 Image Storage (optional — images stored as URLs if not set) ──────
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1
S3_BUCKET=
